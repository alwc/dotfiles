# +----------------------------------------------------------------------------
# | Secrets (not in version control)
# +----------------------------------------------------------------------------
[ -f ~/.secrets ] && source ~/.secrets
[ -f ~/.config/last30days/.env ] && source ~/.config/last30days/.env

# +----------------------------------------------------------------------------
# | SSH palette — repaint the local terminal with a Nord-ish scheme via OSC
# | escapes when this shell is running over SSH, so remote sessions are
# | visually distinct from local ones. Reset on exit so colors don't linger.
# +----------------------------------------------------------------------------
if [[ -n "$SSH_CONNECTION" ]] && [[ -t 1 ]]; then
  _ssh_osc() { printf '\033]%s\007' "$1"; }
  _ssh_osc "10;#d8dee9"   # foreground
  _ssh_osc "11;#2e3440"   # background
  _ssh_osc "12;#d8dee9"   # cursor
  _ssh_osc "4;0;#3b4252"
  _ssh_osc "4;1;#bf616a"
  _ssh_osc "4;2;#a3be8c"
  _ssh_osc "4;3;#ebcb8b"
  _ssh_osc "4;4;#81a1c1"
  _ssh_osc "4;5;#b48ead"
  _ssh_osc "4;6;#88c0d0"
  _ssh_osc "4;7;#e5e9f0"
  _ssh_osc "4;8;#4c566a"
  _ssh_osc "4;9;#bf616a"
  _ssh_osc "4;10;#a3be8c"
  _ssh_osc "4;11;#ebcb8b"
  _ssh_osc "4;12;#81a1c1"
  _ssh_osc "4;13;#b48ead"
  _ssh_osc "4;14;#8fbcbb"
  _ssh_osc "4;15;#eceff4"
  unset -f _ssh_osc
  zshexit() {
    printf '\033]110\007\033]111\007\033]112\007\033]104\007'
  }
  _SSH_PROMPT_OVERRIDE=1
fi

# +----------------------------------------------------------------------------
# | Pretty prompt
# +----------------------------------------------------------------------------
parse_git_branch() {
  git branch 2> /dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/ (\1)/'
}

setopt PROMPT_SUBST
if [[ -n "$_SSH_PROMPT_OVERRIDE" ]]; then
  export PROMPT='%F{cyan}%n%f%F{yellow}@%F{magenta}%m%f%F{white}:%F{green}%~%f%F{blue}$(parse_git_branch)
%F{cyan}%#%f '
else
  export PROMPT='%F{white}%n%f%F{yellow}@%F{red}%m%f%F{white}:%F{green}%~%f%F{blue}$(parse_git_branch)
%F{green}%#%f '
fi

# +----------------------------------------------------------------------------
# | Aliases setup (System)
# +----------------------------------------------------------------------------
## Editor
alias vim="nvim"
alias vi="nvim"

## Safety
alias rm="rm -i"
alias mv="mv -i"
alias cp="cp -i"
set -o noclobber

## Listing, directories, and motion
alias ls="ls --color"
alias ll="ls -alrtF"
alias la="ls -A"
alias l="ls -CF"
alias ..="cd .."
alias ...="cd ..; cd .."
alias md="mkdir"
alias cl="clear"
alias du="du -ch"
alias treeacl="tree -A -C -L 2"

## Homebrew
alias brew-all="brew update && brew upgrade && brew cleanup"
# `brew cu` command comes from 'https://github.com/buo/homebrew-cask-upgrade'
alias brew-cask-all="brew cu -a -y --cleanup"

## Network
alias lsp="lsof -i -n -P | grep LISTEN"

## youtube-dl https://superuser.com/a/1554749
unsetopt nomatch

#------------------------------------------------------------------------------
# Aliases setup (Others)
#------------------------------------------------------------------------------
alias chrome="/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome"

## Folder direct access
alias memex="cd ~/Dropbox/memex"
alias dot="cd ~/dotfiles"
alias dotp="cd ~/dotfiles_private"

# Install another copy of Homebrew for Intel simulated terminal
# https://laict.medium.com/install-homebrew-on-macos-11-apple-silicon-630f37a74490
alias ibrew='arch -x86_64 /usr/local/bin/brew'

alias icat="kitty +kitten icat"

# +----------------------------------------------------------------------------
# | fzf
# +----------------------------------------------------------------------------
# Shell integration (key bindings + fuzzy completion) — requires fzf >= 0.48.0.
# https://github.com/junegunn/fzf#setting-up-shell-integration
if [[ ! "$PATH" == */opt/homebrew/opt/fzf/bin* ]]; then
  PATH="${PATH:+${PATH}:}/opt/homebrew/opt/fzf/bin"
fi
command -v fzf >/dev/null && source <(fzf --zsh)


# --files: List files that would be searched but do not search
# --no-ignore: Do not respect .gitignore, etc...
# --hidden: Search hidden files and folders
# --follow: Follow symlinks
# --glob: Additional conditions for search (in this case ignore everything in the .git/ folder)
export FZF_DEFAULT_COMMAND='rg --files --no-ignore-vcs --hidden --follow -g "!**/node_modules/**" -g "!**/.git/**" -g "!**/.mypy_cache/**" -g "!**/__pycache__/**" -g "!**/.DS_Store" -g "!*.png" -g "!*.jpg" 2> /dev/null'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# +----------------------------------------------------------------------------
# | Claude
# +----------------------------------------------------------------------------
[ -f ~/.claude_config ] && source ~/.claude_config

# +----------------------------------------------------------------------------
# | uv (Python Package Manager)
# +----------------------------------------------------------------------------
# uv doesn't require shell initialization like pyenv
# Python versions and environments are managed via uv commands

# +----------------------------------------------------------------------------
# | Bun (JavaScript Runtime)
# +----------------------------------------------------------------------------
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"

# +----------------------------------------------------------------------------
# | pnpm (Node Package Manager)
# +----------------------------------------------------------------------------
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# +----------------------------------------------------------------------------
# | mise (Dev Tool Manager)
# +----------------------------------------------------------------------------
eval "$(mise activate zsh)"

# +----------------------------------------------------------------------------
# | User-local binaries (~/.local/bin)
# +----------------------------------------------------------------------------
# XDG-conventional install dir for per-user tools not managed by Homebrew or
# mise. Currently holds: lume / lume-update (trycua macOS VM manager) and
# onecli. Installer scripts (curl | sh, pipx, pip install --user) drop binaries
# here by default, so this needs to be on PATH for them to be invokable.
export PATH="$HOME/.local/bin:$PATH"
